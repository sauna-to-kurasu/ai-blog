---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categorySlugMap: Record<string, string> = {
  'はじめ方': 'setup',
  'つくる': 'build',
  '運用': 'ops',
  'Claude Code': 'claude',
  '体験記': 'story',
};
---

<Layout title="AIと暮らす。| 非エンジニアのClaude Code実運用ドキュメンタリー" description="プログラミング経験ゼロの30代会社員が、Claude Code × Astro × Cloudflareで爆速ブログを作る実運用記録。WordPress代替の最適解を探る。">

  {/* Hero Section */}
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-sm font-medium tracking-wider mb-4" style="color: #2A7D6E;">NON-ENGINEER × CLAUDE CODE</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6" style="color: #1F6B5E;">
        コードを書かない。<br/>AIと暮らす。
      </h1>
      <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed mb-8">
        プログラミング経験ゼロの30代会社員が、Claude Codeに話しかけるだけで
        本格ブログを構築・運用している全記録。
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/blog/story-zero-code-blog/" class="inline-flex items-center justify-center px-6 py-3 rounded-lg text-white font-bold text-sm shadow-md hover:opacity-90 transition" style="background-color: #1F6B5E;">
          はじめに読む記事
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="#posts" class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-bold text-sm border-2 transition" style="color: #1F6B5E; border-color: #1F6B5E;">
          記事一覧を見る
        </a>
      </div>
    </div>
  </section>

  {/* Stats */}
  <section class="max-w-5xl mx-auto px-4 mb-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { number: '0行', label: '書いたコード', sub: 'すべてAIに口頭指示' },
        { number: '¥1,550', label: '年間運用コスト', sub: '.devドメイン代のみ' },
        { number: '100点', label: 'Lighthouseスコア', sub: '静的生成×CDN' },
        { number: '0円', label: 'サーバー代', sub: 'Cloudflare Pages無料枠' },
      ].map((stat) => (
        <div class="bg-white rounded-xl p-5 text-center border border-gray-200 shadow-sm">
          <p class="text-2xl md:text-3xl font-bold" style="color: #1F6B5E;">{stat.number}</p>
          <p class="text-sm font-medium text-gray-700 mt-1">{stat.label}</p>
          <p class="text-xs text-gray-400 mt-0.5">{stat.sub}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Posts */}
  <section id="posts" class="max-w-5xl mx-auto px-4 mb-16">
    <h2 class="text-xl font-bold mb-8" style="color: #1F6B5E;">記事一覧</h2>
    {posts.length === 0 ? (
      <div class="bg-white rounded-xl p-10 text-center border border-gray-200">
        <p class="text-gray-500">記事を準備中です。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="group bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all">
            {post.data.heroImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={post.data.heroImage.src}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
                  width={post.data.heroImage.width}
                  height={post.data.heroImage.height}
                />
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                {post.data.category && (
                  <span class="text-[11px] font-medium px-2 py-0.5 rounded-full text-white" style="background-color: rgba(31,107,94,0.85);">
                    {post.data.category}
                  </span>
                )}
                <span class="text-xs text-gray-400">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </div>
              <h3 class="text-[15px] md:text-base font-bold text-gray-800 leading-relaxed group-hover:text-[#1F6B5E] transition-colors">
                {post.data.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

</Layout>
