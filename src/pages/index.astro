---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categorySlugMap: Record<string, string> = {
  'はじめ方': 'setup',
  'つくる': 'build',
  '運用': 'ops',
  'Claude Code': 'claude',
  '体験記': 'story',
};
---

<Layout title="AIと暮らす。| 非エンジニアのClaude Code実運用ドキュメンタリー" description="プログラミング経験ゼロの30代会社員が、Claude Code × Astro × Cloudflareで爆速ブログを作る実運用記録。WordPress代替の最適解を探る。">

  {/* Hero Section - Dark */}
  <section class="relative py-16 md:py-24" style="background-color: #0F172A;">
    {/* CSS Grid Pattern Background */}
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(34,211,238,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(34,211,238,0.04) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative max-w-2xl mx-auto px-4 text-center">
      <p class="text-xs font-medium tracking-[0.15em] mb-4" style="color: #22D3EE;">非エンジニアの、AI実運用記録</p>
      <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-6 text-white" style="letter-spacing: -0.025em;">
        コードを書かない。<br/>AIと暮らす。
      </h1>
      <p class="text-base md:text-lg max-w-2xl mx-auto leading-relaxed mb-10" style="color: #94A3B8;">
        プログラミング経験ゼロの会社員が、AIに話しかけるだけでこのブログを作りました。<br class="hidden md:inline"/>
        かかった費用は年間1,550円。その全記録を公開しています。
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/blog/story-zero-code-blog/" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-bold text-sm shadow-lg hover:opacity-90 transition" style="background-color: #22D3EE; color: #0F172A;">
          はじめに読む記事
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="#posts" class="inline-flex items-center justify-center px-7 py-3 rounded-full font-bold text-sm border transition" style="color: #94A3B8; border-color: rgba(148,163,184,0.3);">
          記事一覧を見る
        </a>
      </div>
    </div>
  </section>

  {/* Stats - Dark Surface */}
  <section class="py-12" style="background-color: #1E293B;">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { number: '0行', label: '書いたコード', sub: 'すべてAIに口頭指示' },
          { number: '¥1,550', label: '年間運用コスト', sub: '.devドメイン代のみ' },
          { number: '100点', label: 'Lighthouseスコア', sub: '静的生成×CDN' },
          { number: '0円', label: 'サーバー代', sub: 'Cloudflare Pages無料枠' },
        ].map((stat) => (
          <div class="rounded-xl p-5 text-center" style="border: 1px solid rgba(255,255,255,0.08);">
            <p class="text-2xl md:text-3xl font-extrabold" style="color: #22D3EE;">{stat.number}</p>
            <p class="text-sm font-medium mt-1" style="color: #E2E8F0;">{stat.label}</p>
            <p class="text-xs mt-0.5" style="color: #64748B;">{stat.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Posts */}
  <section id="posts" class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="text-xl font-bold mb-8" style="color: #0E7490;">記事一覧</h2>
    {posts.length === 0 ? (
      <div class="bg-white rounded-xl p-10 text-center border border-gray-200">
        <p class="text-gray-500">記事を準備中です。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="group bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all">
            {post.data.heroImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={post.data.heroImage.src}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
                  width={post.data.heroImage.width}
                  height={post.data.heroImage.height}
                />
              </div>
            )}
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                {post.data.category && (
                  <span class="text-[11px] font-medium px-2 py-0.5 rounded-full" style="background-color: #0F172A; color: #22D3EE;">
                    {post.data.category}
                  </span>
                )}
                <span class="text-xs text-gray-400">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </div>
              <h3 class="text-[15px] md:text-base font-bold text-gray-800 leading-relaxed group-hover:text-[#0E7490] transition-colors">
                {post.data.title}
              </h3>
              {post.data.description && (
                <p class="text-xs text-gray-500 mt-2 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

</Layout>
