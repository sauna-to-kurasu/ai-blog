---
interface Message {
  role: 'human' | 'ai';
  text: string;
}

interface Props {
  messages: Message[];
}

const { messages } = Astro.props;
---

<div class="ai-chat">
  {messages.map((msg) => (
    msg.role === 'human' ? (
      <div class="ai-chat-human">
        <div class="ai-chat-bubble ai-chat-bubble--human">
          <Fragment set:html={msg.text} />
        </div>
      </div>
    ) : (
      <div class="ai-chat-ai">
        <div class="ai-chat-avatar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <div class="ai-chat-bubble ai-chat-bubble--ai">
          <Fragment set:html={msg.text} />
        </div>
      </div>
    )
  ))}
</div>

<style is:global>
  .article-body .ai-chat {
    max-width: 100%;
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .article-body .ai-chat-human {
    display: flex;
    justify-content: flex-end;
  }

  .article-body .ai-chat-ai {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .article-body .ai-chat-avatar {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: var(--color-cyan, #22D3EE);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-dark, #0F172A);
    margin-top: 2px;
  }

  .article-body .ai-chat-bubble {
    max-width: 80%;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .article-body .ai-chat-bubble p {
    margin-bottom: 0.5rem;
  }
  .article-body .ai-chat-bubble p:last-child {
    margin-bottom: 0;
  }

  .article-body .ai-chat-bubble--human {
    background: var(--color-dark, #0F172A);
    color: #f1f5f9;
    border-radius: 1rem 1rem 0.25rem 1rem;
  }

  .article-body .ai-chat-bubble--ai {
    background: #f1f5f9;
    color: #334155;
    border-radius: 1rem 1rem 1rem 0.25rem;
    border: 1px solid #e2e8f0;
  }

  .article-body .ai-chat-bubble code {
    font-size: 0.8em;
    background: rgba(0, 0, 0, 0.1);
    padding: 0.1em 0.3em;
    border-radius: 0.2rem;
  }

  .article-body .ai-chat-bubble--human code {
    background: rgba(255, 255, 255, 0.15);
  }
</style>
