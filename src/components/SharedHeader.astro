---
interface Props {
  titleTag?: 'h1' | 'span';
}

const { titleTag = 'h1' } = Astro.props;
const TitleTag = titleTag;

const navItems = [
  { label: 'はじめ方', href: '/category/setup/' },
  { label: 'つくる', href: '/category/build/' },
  { label: '運用', href: '/category/ops/' },
  { label: 'Claude Code', href: '/category/claude/' },
  { label: '体験記', href: '/category/story/' },
];
---

<header class="bg-white/95 backdrop-blur-sm shadow-sm sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 h-16 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity group">
      <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white shadow-md transition-transform group-hover:scale-105" style="background-color: #1F6B5E;">
        <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
          <path d="M2 17l10 5 10-5"></path>
          <path d="M2 12l10 5 10-5"></path>
        </svg>
      </div>
      <div class="flex flex-col">
        <TitleTag class="font-bold text-lg leading-none tracking-tight m-0" style="color: #1F6B5E;">
          AIと暮らす。
        </TitleTag>
        <span class="text-[10px] text-gray-400 tracking-wider">LIVING WITH AI</span>
      </div>
    </a>

    {/* Desktop nav */}
    <nav class="hidden md:flex items-center gap-6 text-sm font-bold">
      {navItems.map((item) => (
        <a href={item.href} class="text-gray-600 hover:text-[#1F6B5E] transition">{item.label}</a>
      ))}
    </nav>

    {/* Mobile hamburger */}
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-600 hover:text-[#1F6B5E] transition"
      aria-label="メニューを開く"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  {/* Mobile menu overlay */}
  <div id="mobile-menu" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/50" id="mobile-menu-overlay"></div>
    <div class="absolute top-0 right-0 h-full w-72 bg-white shadow-xl transform translate-x-full transition-transform duration-300" id="mobile-menu-panel">
      <div class="flex items-center justify-between p-4 border-b border-gray-100">
        <span class="font-bold text-sm" style="color: #1F6B5E;">メニュー</span>
        <button id="mobile-menu-close" class="p-2 text-gray-400 hover:text-gray-600" aria-label="メニューを閉じる">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="p-4 space-y-1">
        {navItems.map((item) => (
          <a href={item.href} class="block px-4 py-3 text-sm text-gray-700 hover:bg-[#EEF6F4] hover:text-[#1F6B5E] rounded-lg transition">
            {item.label}
          </a>
        ))}
        <div class="border-t border-gray-100 mt-4 pt-4">
          <a href="/profile/" class="block px-4 py-3 text-sm text-gray-700 hover:bg-[#EEF6F4] hover:text-[#1F6B5E] rounded-lg transition">
            プロフィール
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const panel = document.getElementById('mobile-menu-panel');
  const overlay = document.getElementById('mobile-menu-overlay');
  const close = document.getElementById('mobile-menu-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    requestAnimationFrame(() => {
      panel?.classList.remove('translate-x-full');
    });
  }

  function closeMenu() {
    panel?.classList.add('translate-x-full');
    setTimeout(() => menu?.classList.add('hidden'), 300);
  }

  btn?.addEventListener('click', openMenu);
  overlay?.addEventListener('click', closeMenu);
  close?.addEventListener('click', closeMenu);
</script>
