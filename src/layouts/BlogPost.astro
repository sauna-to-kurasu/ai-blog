---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SharedHeader from '../components/SharedHeader.astro';
import SharedFooter from '../components/SharedFooter.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: number };

const { title, description, pubDate, updatedDate, heroImage, category, readingTime } = Astro.props;

const categorySlugMap: Record<string, string> = {
  'はじめ方': 'setup',
  'つくる': 'build',
  '運用': 'ops',
  'Claude Code': 'claude',
  '体験記': 'story',
};

const categorySlug = category ? categorySlugMap[category] || 'other' : null;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
  </head>

  <body class="min-h-screen font-sans text-slate-700 font-normal" style="background-color: #F4F8F7; font-family: 'Noto Sans JP', sans-serif;">

    <!-- Article Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "datePublished": pubDate.toISOString(),
      ...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
      "author": {
        "@type": "Person",
        "name": "AIと暮らす人",
        "url": "https://ai-to-kurasu.dev/profile/"
      },
      ...(heroImage ? { "image": `https://ai-to-kurasu.dev${heroImage.src}` } : {}),
      "publisher": {
        "@type": "Organization",
        "name": "AIと暮らす。",
        "url": "https://ai-to-kurasu.dev"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://ai-to-kurasu.dev${Astro.url.pathname}`
      }
    })} />

    <div id="reading-progress" style="position:fixed;top:0;left:0;width:0;height:3px;background:linear-gradient(90deg,#22D3EE,#06B6D4);z-index:100;transition:width 100ms ease-out;" aria-hidden="true"></div>
    <SharedHeader titleTag="span" />

    <!-- Article Header - Dark -->
    <div style="background-color: #0F172A;">
      {/* ヒーロー画像（あれば表示） */}
      {heroImage && (
        <div class="max-w-4xl mx-auto">
          <div class="w-full relative aspect-[16/9]">
            <img
              src={heroImage.src}
              alt={title}
              class="absolute inset-0 w-full h-full object-cover"
              style="border-radius: 0 0 1rem 1rem;"
              width={heroImage.width}
              height={heroImage.height}
            />
          </div>
        </div>
      )}

      {/* タイトル・メタ情報 */}
      <div class="max-w-3xl mx-auto px-4 py-8 md:py-10">
        {/* パンくず */}
        <div class="text-sm mb-4 overflow-x-auto whitespace-nowrap" style="color: #64748B;">
          <a href="/" class="hover:underline" style="color: #64748B;">ホーム</a>
          <span class="mx-2" style="color: #475569;">&gt;</span>
          {category && categorySlug && (
            <>
              <a href={`/category/${categorySlug}/`} class="hover:underline" style="color: #64748B;">{category}</a>
              <span class="mx-2" style="color: #475569;">&gt;</span>
            </>
          )}
          <span style="color: #94A3B8;">{title}</span>
        </div>

        {category && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-bold mb-4" style="background-color: rgba(34,211,238,0.15); color: #22D3EE;">
            {category}
          </span>
        )}
        <h1 class="text-xl md:text-2xl font-extrabold leading-snug mb-4 text-white">
          {title}
        </h1>
        <div class="flex flex-wrap gap-4 text-xs" style="color: #64748B;">
          <div class="flex items-center gap-1">
            <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
          </div>
          {updatedDate && (
            <div class="flex items-center gap-1" style="color: #475569;">
              （更新: {updatedDate.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}）
            </div>
          )}
          <div class="flex items-center gap-1">
            <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            AIと暮らす人
          </div>
          {readingTime && (
            <div class="flex items-center gap-1">
              <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              約{readingTime}分で読めます
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="max-w-3xl mx-auto px-4 pb-16 pt-8">
      <article>

        {/* 記事本文 */}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10 article-body">
          <slot />
        </div>

        {/* 記事末尾CTA */}
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-lg text-white font-bold text-sm shadow-md hover:opacity-90 transition" style="background-color: #0E7490;">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/>
            </svg>
            ホームへ戻る
          </a>
          {category && categorySlug && (
            <a href={`/category/${categorySlug}/`} class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-bold text-sm border-2 transition" style="color: #0E7490; border-color: #0E7490;">
              「{category}」の記事をもっと読む
            </a>
          )}
        </div>
      </article>
    </main>

    <SharedFooter />

    <script>
      const bar = document.getElementById('reading-progress');
      const article = document.querySelector('.article-body');
      if (bar && article) {
        window.addEventListener('scroll', () => {
          const rect = article.getBoundingClientRect();
          const articleTop = rect.top + window.scrollY;
          const articleHeight = rect.height;
          const scrolled = window.scrollY - articleTop;
          const pct = Math.min(100, Math.max(0, (scrolled / (articleHeight - window.innerHeight)) * 100));
          bar.style.width = pct + '%';
        }, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/article-body-ai.css";

  /* article-body のフォントサイズ（レスポンシブ） */
  .article-body {
    font-size: 15px;
  }
  @media (min-width: 768px) {
    .article-body {
      font-size: 17px;
    }
  }
</style>
