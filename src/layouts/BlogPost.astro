---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SharedHeader from '../components/SharedHeader.astro';
import SharedFooter from '../components/SharedFooter.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;

const categorySlugMap: Record<string, string> = {
  'はじめ方': 'setup',
  'つくる': 'build',
  '運用': 'ops',
  'Claude Code': 'claude',
  '体験記': 'story',
};

const categorySlug = category ? categorySlugMap[category] || 'other' : null;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
  </head>

  <body class="min-h-screen font-sans text-slate-700 font-normal" style="background-color: #F5F7F9; font-family: 'Noto Sans JP', sans-serif;">

    <!-- Article Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "datePublished": pubDate.toISOString(),
      ...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
      "author": {
        "@type": "Person",
        "name": "AIと暮らす人",
        "url": "https://ai-to-kurasu.dev/profile/"
      },
      ...(heroImage ? { "image": `https://ai-to-kurasu.dev${heroImage.src}` } : {}),
      "publisher": {
        "@type": "Organization",
        "name": "AIと暮らす。",
        "url": "https://ai-to-kurasu.dev"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://ai-to-kurasu.dev${Astro.url.pathname}`
      }
    })} />

    <SharedHeader titleTag="span" />

    <!-- BREADCRUMB -->
    <div class="max-w-5xl mx-auto px-4 py-4 text-xs text-gray-500 overflow-x-auto whitespace-nowrap">
      <a href="/" class="text-gray-500 hover:text-[#204070] hover:underline">ホーム</a>
      <span class="mx-2 text-gray-300">&gt;</span>
      {category && categorySlug && (
        <>
          <a href={`/category/${categorySlug}/`} class="text-gray-500 hover:text-[#204070] hover:underline">{category}</a>
          <span class="mx-2 text-gray-300">&gt;</span>
        </>
      )}
      <span>{title}</span>
    </div>

    <!-- MAIN CONTENT -->
    <main class="max-w-5xl mx-auto px-4 pb-16">
      <article class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        {/* Hero image */}
        {heroImage && (
          <div class="aspect-video overflow-hidden">
            <img
              src={heroImage.src}
              alt={title}
              class="w-full h-full object-cover"
              width={heroImage.width}
              height={heroImage.height}
            />
          </div>
        )}

        {/* Article header */}
        <div class="px-6 md:px-10 pt-8 pb-4">
          <div class="flex items-center gap-3 text-xs text-gray-500 mb-4">
            {category && (
              <span class="px-2.5 py-1 rounded-full text-white text-[11px] font-medium" style="background-color: rgba(32,64,112,0.85);">
                {category}
              </span>
            )}
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="text-gray-400">
                （更新: <FormattedDate date={updatedDate} />）
              </span>
            )}
          </div>
          <h1 class="text-xl md:text-2xl font-bold leading-relaxed" style="color: #1f2937;">
            {title}
          </h1>
        </div>

        {/* Article body */}
        <div class="article-body px-6 md:px-10 pb-10">
          <slot />
        </div>
      </article>
    </main>

    <SharedFooter />
  </body>
</html>

<style is:global>
  /* Article body typography */
  .article-body {
    font-size: 15px;
    line-height: 1.9;
    color: #333333;
  }
  @media (min-width: 768px) {
    .article-body {
      font-size: 17px;
    }
  }

  .article-body h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #204070;
    color: #1f2937;
  }
  @media (min-width: 768px) {
    .article-body h2 {
      font-size: 1.375rem;
    }
  }

  .article-body h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    padding-left: 0.75rem;
    border-left: 3px solid #204070;
    color: #1f2937;
  }

  .article-body p {
    margin-bottom: 1.5rem;
  }

  .article-body a {
    color: #204070;
    text-decoration: underline;
    text-decoration-color: rgba(32, 64, 112, 0.3);
    text-underline-offset: 3px;
  }
  .article-body a:hover {
    color: #3A6090;
  }

  .article-body img {
    border-radius: 8px;
    height: auto;
    max-width: 100%;
  }

  .article-body ul, .article-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .article-body li {
    margin-bottom: 0.5rem;
  }

  .article-body strong {
    font-weight: 700;
    color: #1f2937;
  }

  /* Code blocks */
  .article-body pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1.25rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 14px;
    line-height: 1.7;
  }
  .article-body code {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, Consolas, monospace;
    font-size: 0.875em;
  }
  .article-body :not(pre) > code {
    background: #f1f5f9;
    color: #204070;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.85em;
  }

  /* Tables */
  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 14px;
  }
  .article-body th {
    background: #F0F4F8;
    color: #204070;
    font-weight: 700;
    padding: 0.75rem;
    text-align: left;
    border-bottom: 2px solid #dce3ed;
  }
  .article-body td {
    padding: 0.75rem;
    border-bottom: 1px solid #f0f1f3;
  }
  .article-body tr:nth-child(even) {
    background: #fafbfc;
  }

  /* Blockquote */
  .article-body blockquote {
    border-left: 3px solid #204070;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    background: #F0F4F8;
    border-radius: 0 0.5rem 0.5rem 0;
    color: #333;
  }

  /* Image captions */
  .blog-image-caption {
    display: block;
    text-align: center;
    font-size: 13px;
    color: #6b7280;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  /* Info highlight box */
  .info-highlight-box {
    background: #F0F4F8;
    border-left: 4px solid #204070;
    border-radius: 0 0.75rem 0.75rem 0;
    padding: 1.25rem;
    margin: 1.5rem 0;
  }
  .info-highlight-box p {
    margin-bottom: 0.5rem;
  }
  .info-highlight-box p:last-child {
    margin-bottom: 0;
  }
</style>
